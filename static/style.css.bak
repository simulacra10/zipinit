body {
  font-family: serif;
  margin: 2em auto;
  padding: 0 1em;
  max-width: 70ch;
  line-height: 1.6;
}

    h1, h2, h3 {
      font-weight: normal;
    }

    .meta {
      font-size: 0.95em;
      color: #555;
      margin-bottom: 1.5em;
    }

    .callout {
      border-left: 3px solid #999;
      padding-left: 1em;
      margin: 1.5em 0;
    }

    ul { padding-left: 1.2em; }

    hr { margin: 2em 0; }

    footer {
      margin-top: 3em;
      font-size: 0.9em;
      color: #555;
    }

    @media print {
      a { color: inherit; text-decoration: none; }
      body { margin: 1in; }
    }